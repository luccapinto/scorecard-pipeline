# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
# anchored to repo root so it ignores Python's ./dist but not frontend/dist
/dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
.venv/
venv/
ENV/
env/

# Environment variables
.env

# Node / frontend build deps (the built SPA in frontend/dist is committed;
# its node_modules is not — heavy and regenerable via `npm install`).
node_modules/

# Database files
*.sqlite3
*.db

# Generated data: JSON context files are committed so the pipeline works
# on a fresh clone; synthesized audio is not (heavy, regenerable).
data/**/*.wav
data/**/*.mp3

# Test/lint artifacts
.coverage
htmlcov/
.pytest_cache/
.ruff_cache/

# Redis snapshots
dump.rdb
