# Database Config
DATABASE_URL=postgresql://postgres:postgres_secure_pass@localhost:5432/scorecard_db

# Redis Config
REDIS_URL=redis://localhost:6379/0

# Transcription + diarization provider:
#   "deepgram" (default) — nova-3 API, transcription + speaker diarization in a
#                          single call; no local ML models, no HF_TOKEN.
#   "local"              — WhisperX + pyannote, fully offline; requires
#                          requirements-ml.txt and HF_TOKEN.
#   "openai"             — whisper-1 API for transcription; still needs local
#                          pyannote (+ HF_TOKEN) for diarization.
TRANSCRIPTION_PROVIDER=deepgram
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
# Required: Deepgram defaults to English and returns empty output on mismatch.
# "multi" (code-switching) keeps English tech terms that "pt" drops.
DEEPGRAM_LANGUAGE=multi

# Only needed for TRANSCRIPTION_PROVIDER=local or openai:
OPENAI_API_KEY=
HF_TOKEN=
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=pt

# Scoring (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Notifications
SLACK_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_URL=
API_BASE_URL=http://localhost:8000

# Security — ALWAYS set these in production.
# HMAC-SHA256 secret verified against the X-Webhook-Signature header.
WEBHOOK_HMAC_SECRET=
# API key required (X-API-Key header) on read/action endpoints.
API_KEY=
# Restrict local recording paths to this directory (empty = dev mode, any path).
AUDIO_ALLOWED_DIR=

# Job processing
JOB_TIMEOUT_SECONDS=7200
JOB_MAX_RETRIES=3
MAX_AUDIO_BYTES=524288000

# Maintenance
STALE_RECEBIDA_MAX_AGE_MINUTES=15
# 0 disables LGPD retention purging
RETENTION_DAYS=0

# Logging
LOG_JSON=false
