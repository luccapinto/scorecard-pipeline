# Normalize line endings: LF in the repository, native on checkout.
* text=auto

# Files that must keep LF even on Windows checkouts — they run inside Linux
# containers, where CRLF breaks the shebang/interpreter line.
*.sh text eol=lf
entrypoint.sh text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary assets: never diff or normalize.
*.wav binary
*.mp3 binary
*.m4a binary
*.png binary
*.jpg binary
*.db binary
*.rdb binary

# Generated frontend bundle: keep out of diffs and language stats.
frontend/dist/** linguist-generated=true -diff
